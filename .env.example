# === BẮT BUỘC ===

# MongoDB Atlas connection string
MONGODB_URI="mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/ios-finance"

# API Key cho OpenAI-compatible endpoint
# - OpenRouter: lấy từ https://openrouter.ai/keys (dạng sk-or-...)
# - FreeLLMAPI: lấy từ dashboard Keys (dạng freellmapi-...)
GEMINI_API_KEY="sk-or-..."

# API Base URL (OpenAI-compatible)
# - OpenRouter: https://openrouter.ai/api/v1 (mặc định)
# - FreeLLMAPI local: http://localhost:0801/v1
GEMINI_API_BASE_URL="https://openrouter.ai/api/v1"

# Model name
# - OpenRouter: google/gemini-2.5-flash (mặc định)
# - FreeLLMAPI: gemini-3.5-flash, gemini-2.5-flash, gemini-2.5-flash-lite
GEMINI_MODEL="google/gemini-2.5-flash"

# JWT secret key (chuỗi bí mật bất kỳ)
JWT_SECRET="chuoi-bi-mat-bat-ky"

# === DISCORD BOT (chỉ cần khi triển khai Phase 3) ===

# Lấy từ Discord Developer Portal → App → General Information
DISCORD_APP_ID="123456789012345678"
DISCORD_PUBLIC_KEY="abc123def456..."

# Lấy từ Discord Developer Portal → App → Bot
DISCORD_BOT_TOKEN="MTk4NjIyNDgzNDk3NDQ1MjM4..."

# Discord User ID của bạn (chuột phải → Copy ID, bật Developer Mode)
DISCORD_USER_ID="987654321098765432"
